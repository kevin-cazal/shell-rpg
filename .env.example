# Guest RAM for v86 (must match bundle memory_size)
VITE_VM_MEMORY_MB=256

# Path prefix for production (GitHub Pages sets this in CI)
# VITE_BASE=/shell-rpg/

# Bundle download URLs (pick overlay: CDN primary, GitHub mirror)
VITE_OFFICIAL_BUNDLE_URL=https://cdn.cazal.eu/shell-rpg-256M.v86b
VITE_MIRROR_BUNDLE_URL=https://github.com/kevin-cazal/shell-rpg-vm-image/releases/latest/download/shell-rpg-256M.v86b
